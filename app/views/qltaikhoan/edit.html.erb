                        <li><%= link_to "Quản lý khoa - đơn vị", qlkhoa_dv_qlkhoa_dv_path %></li>
                        <li><%= link_to "Quản lý hồ sơ", xlhoso_xlhoso_path %></li>
                        <li><%= link_to "Thống kê báo cáo", thongkebaocao_thongkebaocao_path %></li>
                    </ul>
                </li>
            <% end %>
            <% if current_user %>
    <li class="user-dropdown">
        <a href="#" class="user-name">
             <%= current_user.USERNAME %>
        </a>
        <ul class="user-dropdown-menu">
            <li><%= link_to "Thông tin tài khoản", thongtintaikhoan_thongtintaikhoan_path %></li>
            <li>
                <%= button_to "Đăng xuất",
                "/dangnhap/logout",
                method: :delete,
                class: "logout-btn",
                form: { style: "display:inline;" } %>
            </li>
        </ul>
    </li>
<% else %>
    <li>
        <%= link_to "Đăng nhập", dangnhap_dangnhap_path %>
    </li>
<% end %>
        </ul>
    </nav>
</header>
<div class="edit-container-wrap">
<div class="edit-container">

    <h1>Sửa tài khoản</h1>

    <%= form_with url: "/qltaikhoan/update/#{@user.IDNGUOIDUNG}",
        method: :patch,
        local: true do %>

        <div class="form-group">
            <label>UserName</label>

            <%= text_field_tag :USERNAME,
                @user.USERNAME,
                class: "form-input" %>
        </div>

        <div class="form-group">
            <label>Email</label>

            <%= text_field_tag :EMAIL,
                @user.EMAIL,
                class: "form-input" %>
        </div>

        <div class="form-group">
            <label>Vai trò</label>

            <%= select_tag :VAITRO,
                options_for_select(
                    ["ADMIN", "THISINH"],
                    @user.VAITRO
                ),
                class: "form-input" %>
        </div>

        <div class="button-group">

            <%= submit_tag "💾 Lưu",
                class: "btn-save",
                onclick: "return confirm('Bạn có chắc muốn lưu thay đổi?')" %>

            <%= link_to "⬅ Quay về",
                qltaikhoan_qltaikhoan_path,
                class: "btn-back" %>

        </div>

    <% end %>

</div>
</div>
