<div class="header">
        <div class="logo">
            <%= image_tag "logovlute.png",  width: 50 %>
            Hệ Thống Tư Vấn Tuyển Sinh
        </div>
        <ul class="menu">
            <li><%= link_to "Trang chủ", trangchu_index_path %></li>
            <li><%=link_to "QL tài khoản", qltaikhoan_qltaikhoan_path %></li>
            <li><%=link_to "Xử lý hồ sơ thí sinh", xlhoso_xlhoso_path %></li>
            <li>QL thông tin tuyển sinh</li>
            <li>QL ngành học</li>
            <li><%=link_to "QL tin tức", qltintuc_qltintuc_path %></li>
            <li>Chatbot AI</li>
            <li>Thống kê và báo cáo</li>
        </ul>
</div>
<main>
        <div class="actions">
            <button class="btn-add"><%= link_to "+Thêm", dangkytk_dangkytk_path %></button>
            
        </div>
            <table class="taikhoan">
                    <tr class="head">
                        <th>STT</th>
                        <th>Mã tài khoản</th>
                        <th>UserName</th>
                        <th>Pass</th>
                        <th>Email</th>
                        <th>Vai trò</th>
                        <th></th>
                    </tr>
                    
                    <% @nguoidungs.each_with_index do |user, index| %>
                        <tr>
                            <td><%= index + 1 %></td>
                            <td><%= user.IDNGUOIDUNG %></td>
                            <td><%= user.USERNAME %></td>
                            <td><%= user.MATKHAU %></td>
                            <td><%= user.EMAIL %></td>
                            <td><%= user.VAITRO %></td>
                            <td>
                                <button class="btn-delete">🗑️ Xóa</button>
                                <button class="btn-up">✎ Sửa</button>
                            </td>
                        </tr>
                    <% end %>
            </table>
</main>

<div class="footer">
    <div class="footer-content">
        <div class="footer1">
            <h3>Về Chúng Tôi</h3>
            <p style="color: #94a3b8; line-height: 1.8;">
                Hệ thống tư vấn tuyển sinh.
            </p>
        </div>
        <div class="footer1">
            <h3>Liên Kết Nhanh</h3>
            <ul>
                <li>Ngành học</li>
                <li>Lịch tuyển sinh</li>
                <li>Nộp hồ sơ</li>
                <li>Câu hỏi thường gặp</li>
            </ul>
        </div>
        <div class="footer1">
            <h3>Liên Hệ</h3>
            <ul>
                <li>Hotline: 123</li>
                <li>Email: tuyensinh@vlute.edu.vn</li>
                <li>Địa chỉ: Vĩnh Long</li>
                <li>Giờ làm việc: 8:00 - 17:00</li>
            </ul>
        </div>
    </div>
    <div class="footer2">
        <p>&copy; 2026 Hệ Thống Tư Vấn Tuyển Sinh </p>
    </div>
</div>