<section class="school-info" id="about">
    <div class="school-container">
        <div class="school-header">
            <h2 class="section-title">Thông Tin Trường</h2>
            <p class="section-subtitle">Tìm hiểu về trường đại học của chúng tôi</p>
        </div>

        <div class="school-content">
            <div class="school-overview">
                <div class="overview-image">
                    <%= image_tag "thongtin.jpg",  width: 500 %>
                </div>
