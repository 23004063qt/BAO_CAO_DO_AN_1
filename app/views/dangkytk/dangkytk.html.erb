<div class="header">
        <div class="logo">
            <%= image_tag "logovlute.png",  width: 50 %>
            Hệ Thống Tư Vấn Tuyển Sinh
        </div>
        <ul class="menu">
            <li><%= link_to "Trang chủ", trangchu_index_path %></li>
            <li>Thông Tin Trường</li>
            <li>Tin Tức</li>
            <li>Ngành Học</li>
            <li>Lịch Tuyển Sinh</li>
            <li><%= link_to "Nộp hồ sơ", nophoso_nophoso_path %></li>
            <li><%= link_to "Đăng nhập", dangnhap_dangnhap_path %></li>
        </ul>
</div>

<div class="content">
    <form class="form_dangkytk">
        <label>ĐĂNG KÝ TÀI KHOẢN</label>
        <table>
            <tr>
                <th>Họ và tên: </th>
                <th>
                    <input type="text" name="hoten" placeholder="Nhập họ và tên">
                </th>
            </tr>

            <tr>
                <th>Tên tài khoản: </th>
                <th>
                    <input type="text" name="tentk" placeholder="Nhập tên tài khoản">
                </th>
            </tr>

            <tr>
                <th>Email: </th>
                <th>
                    <input type="email" name="email" placeholder="Nhập địa chỉ email">
                </th>
            </tr>

            <tr>
                <th>Nhập mật khẩu: </th>
                <th>
                    <input type="password" name="matkhau" placeholder="Nhập mật khẩu">
                </th>
            </tr>

            <tr>
                <th></th>
                <th>
                    <button type="submit">Thêm tài khoản</button>
                </th>
            </tr>
        </table>
    </form>
</div>
</div>
<div class="footer">
    <div class="footer-content">
        <div class="footer1">
            <h3>Về Chúng Tôi</h3>
            <p style="color: #94a3b8; line-height: 1.8;">
                Hệ thống tư vấn tuyển sinh.
            </p>
        </div>
        <div class="footer1">
            <h3>Liên Kết Nhanh</h3>
            <ul>
                <li>Ngành học<</li>
                <li>Lịch tuyển sinh</li>
                <li>Nộp hồ sơ</li>
                <li>Câu hỏi thường gặp</li>
            </ul>
        </div>
        <div class="footer1">
            <h3>Liên Hệ</h3>
            <ul>
                <li>Hotline: 123</li>
                <li>Email: tuyensinh@vlute.edu.vn</li>
                <li>Địa chỉ: Vĩnh Long</li>
                <li>Giờ làm việc: 8:00 - 17:00</li>
            </ul>
        </div>
    </div>
    <div class="footer2">
        <p>&copy; 2026 Hệ Thống Tư Vấn Tuyển Sinh </p>
    </div>
</div>