<section class="score-calculator" id="transcript-calculator" style="background: white;">
    <h2 class="section-title">Tính Điểm Xét Học Bạ</h2>
    <p class="section-subtitle">Nhập điểm các môn học theo từng học kỳ lớp 10, 11, 12</p>
    <div id="tinhdiemhocba">
                <label><h3>Thông tin học tập</h3></label>
                <%
                    #Danh sách khối lớp
                    ds_lop = [10,11,12]

                    #Danh sách học kỳ 
                    ds_hk = [1, 2]

                    # Danh sách môn học
                    ds_mon = [
                    ["toan", "Toán"],
                    ["van", "Ngữ Văn"],
                    ["anh", "Tiếng Anh"],
                    ["ly", "Vật Lý"],
                    ["hoa", "Hóa"],
                    ["sinh", "Sinh Học"],
                    ["su", "Lịch Sử"],
                    ["dia", "Địa"],
                    ["tin", "Tin Học"],
                    ["gdkt", "GDKT và PL"],
                    ["gdcd", "GDCD"],
                    ["cn", "Công nghệ công nghiệp"],
                    ["cnn", "Công nghệ nông nghiệp"]
                    ]
                %>
                <!-- Tạo biến lớp, lấy từng phần tử lớp trong danh sách lớp -->
                <% ds_lop.each do |lop| %>

                <div class="khoi-lop">

                    <h3 class="tieu-de-lop">
                        Lớp <%= lop %>
                    </h3>

                    <% ds_hk.each do |hk| %>

                        <h4 class="tieu-de-hocky">
                            Học kì <%= hk %> lớp <%= lop %>
                        </h4>

                        <div class="luoi-mon-hoc">

                            <% ds_mon.each do |ma_mon, ten_mon| %>

                                <div class="o-mon-hoc">

                                    <label>
                                        <%= ten_mon %>
                                    </label>

                                    <input type="number"
                                        id="l<%= lop %>hk<%= hk %>-<%= ma_mon %>"
                                        min="0"
                                        max="10"
                                        step="0.1"
                                        placeholder="Nhập điểm">

                                </div>

                            <% end %>

                        </div>

                    <% end %>
                </div>
        <% end %>
    </div>
    <div class="tinhdiem-action">
        <button type="button" id="btnTinhDiem" class="btn-tinhdiem">
            Tính điểm
        </button>
    </div>

    <div id="ketquaTinhDiem" class="ketqua" style="display:none;">

        <h3>Kết quả xét học bạ theo tổ hợp</h3>

        <div id="bangKetQua"></div>

    </div>
        
</section>

