<script>

document
.getElementById("btnTinhDiem")
.addEventListener("click", async function() {

    const diem = {};

    document
    .querySelectorAll("#tinhdiemhocba input")
    .forEach(input => {

        diem[input.id] = input.value || 0;

    });

    try {

        const response = await fetch("/tinh", {

            method: "POST",

            headers: {
                "Content-Type": "application/json",
                "X-CSRF-Token":
                    document.querySelector(
                        "meta[name='csrf-token']"
                    ).content
            },

            body: JSON.stringify({
                diem: diem
            })

        });

        if (!response.ok) {
            throw new Error(
                `HTTP ${response.status}`
            );
        }

        const json = await response.json();

        const data = json.data || json;

        data.sort((a,b) => b.tong - a.tong);

        let html = `
            <table class="bang-diem-tohop">
                <thead>
                    <tr>
                        <th>Tổ hợp</th>
                        <th>Môn 1</th>
                        <th>Môn 2</th>
                        <th>Môn 3</th>
                        <th>Tổng điểm</th>
                    </tr>
                </thead>
                <tbody>
        `;

        data.forEach(item => {

            html += `
                <tr>
                    <td>${item.tohop}</td>

                    <td>
                        ${item.mon1}
                        <br>
                        <strong>${item.diem1}</strong>
                    </td>

                    <td>
                        ${item.mon2}
                        <br>
                        <strong>${item.diem2}</strong>
                    </td>

                    <td>
                        ${item.mon3}
                        <br>
                        <strong>${item.diem3}</strong>
                    </td>

                    <td class="tong-diem">
                        ${item.tong}
                    </td>
                </tr>
            `;

        });

        html += `
                </tbody>
            </table>
        `;

        document.getElementById(
            "bangKetQua"
        ).innerHTML = html;

        document.getElementById(
            "ketquaTinhDiem"
        ).style.display = "block";

        document.getElementById(
            "ketquaTinhDiem"
        ).scrollIntoView({
            behavior: "smooth"
        });

    }
    catch(error){

        console.error(error);

        alert(
            "Có lỗi khi tính điểm."
        );

    }

});

</script>