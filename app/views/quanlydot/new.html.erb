<main>

    <h1 class="page-title">
        Thêm đợt tuyển sinh
    </h1>

    <div class="form-card">

        <%= form_with model: @dot,
            url: "/quanlydot/them",
            local: true do |f| %>

            <div class="form-group">
                <label>Tên đợt tuyển sinh</label>

                <%= f.text_field :TENDOT,
                    class: "form-control",
                    required: true %>
            </div>

            <div class="form-group">
                <label>Ngày bắt đầu</label>

                <%= f.date_field :NGAYBATDAU,
                    class: "form-control",
                    required: true %>
            </div>

            <div class="form-group">
                <label>Ngày kết thúc</label>

                <%= f.date_field :NGAYKETTHUC,
                    class: "form-control",
                    required: true %>
            </div>

            <%= f.submit "Lưu đợt tuyển sinh",
                class: "btn-save" %>

        <% end %>

    </div>

</main>