<main>

    <h1 class="page-title">
        Quản lý đợt tuyển sinh
    </h1>

    <%= link_to "Thêm đợt tuyển sinh",
            "/quanlydot/them",
            class: "btn-them" %>

    <div class="table-wrapper">

        <table class="table-dot">

            <thead>
                <tr>
                    <th>ID</th>
                    <th>Tên đợt</th>
                    <th>Ngày bắt đầu</th>
                    <th>Ngày kết thúc</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>

            <tbody>

                <% @dots.each do |dot| %>

                <tr>

                    <td><%= dot.IDDOT %></td>

                    <td><%= dot.TENDOT %></td>

                    <td><%= dot.NGAYBATDAU %></td>

                    <td><%= dot.NGAYKETTHUC %></td>

                    <td>

                        <% if Date.today < dot.NGAYBATDAU %>

                            <span class="status-pending">
                                Chưa diễn ra
                            </span>

                        <% elsif Date.today <= dot.NGAYKETTHUC %>

                            <span class="status-active">
                                Đang diễn ra
                            </span>

                        <% else %>

                            <span class="status-expired">
                                Hết hạn
                            </span>

                        <% end %>

                    </td>

                    <td>
                        <%= link_to "Sửa",
                        "/quanlydot/#{dot.IDDOT}/sua",
                        class: "action-link edit-link" %>

                        <%= button_to "Xóa",
                            "/quanlydot/#{dot.IDDOT}",
                            method: :delete,
                            data: {
                                turbo_confirm: "Bạn có chắc muốn xóa đợt tuyển sinh này?"
                            },
                            class: "btn-delete" %>
                        </a>
                    </td>

                </tr>

                <% end %>

            </tbody>

        </table>

    </div>

</main>

