<div class="header">
        <div class="logo">
            <%= image_tag "logovlute.png",  width: 50 %>
            Hệ Thống Tư Vấn Tuyển Sinh
        </div>
        <ul class="menu">
            <li><%= link_to "Trang chủ", trangchu_index_path %></li>
            <li><%=link_to "QL tài khoản", qltaikhoan_qltaikhoan_path %></li>
            <li>Xử lý hồ sơ thí sinh</li>
            <li>QL thông tin tuyển sinh</li>
            <li>QL ngành học</li>
            <li><%=link_to "QL tin tức", qltintuc_qltintuc_path %></li>
            <li>Chatbot AI</li>
            <li>Thống kê và báo cáo</li>
        </ul>
</div>
<main class="container">

    <h1 class="tieude">THÊM MỚI BÀI ĐĂNG</h1>

    <div class="noidung">

        <!-- CỘT TRÁI -->
        <div class="trai">

            <label>Tiêu đề</label>
            <input type="text" placeholder="Nhập tiêu đề bài đăng">

            <label>Tóm tắt nội dung</label>
            <textarea rows="3" placeholder="Nhập tóm tắt"></textarea>

            <label>Nội dung chi tiết của bài đăng</label>
            <textarea rows="6" placeholder="Nhập nội dung"></textarea>

            <div class="image">
                <p>Hình ảnh bài viết</p>
                <div class="upload">
                    <span>Chọn hình ảnh</span>
                </div>
            </div>

            <textarea rows="4" placeholder="Nhập nội dung thêm"></textarea>

        </div>

        <!-- CỘT PHẢI -->
        <div class="phai">

            <label>Ảnh đại diện</label>
            <div class="anhdaidien">
                <span>Chọn và tải lên</span>
            </div>
            <div class="nut">
                <button class="btn-submit">Đăng tải</button>
                <button class="btn-cancel">Hủy bỏ</button>
            </div>

        </div>

    </div>

</main>  

