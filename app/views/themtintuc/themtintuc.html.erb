                    <%= link_to "Quản trị viên", "#" %>
                    <ul class="dropdown-menu">
                        <li><%= link_to "Quản lý tài khoản", qltaikhoan_qltaikhoan_path %></li>
                        <li><%= link_to "Quản lý tin tức", qltintuc_qltintuc_path %></li>
                        <li><%= link_to "Quản lý khoa - đơn vị", qlkhoa_dv_qlkhoa_dv_path %></li>
                        <li><%= link_to "Quản lý hồ sơ", xlhoso_xlhoso_path %></li>
                        <li><%= link_to "Quản lý đợt tuyển sinh","/quanlydot" %></li>
                        <li><%= link_to "Thống kê báo cáo", thongkebaocao_thongkebaocao_path %></li>
                    </ul>
                </li>
            <% end %>
            <% if current_user %>
    <li class="user-dropdown">
        <a href="#" class="user-name">
             <%= current_user.USERNAME %>
        </a>
        <ul class="user-dropdown-menu">
            <li><%= link_to "Thông tin tài khoản", thongtintaikhoan_thongtintaikhoan_path %></li>
            <li>
                <%= button_to "Đăng xuất",
                "/dangnhap/logout",
                method: :delete,
                class: "logout-btn",
                form: { style: "display:inline;" } %>
            </li>
        </ul>
    </li>
<% else %>
    <li>
        <%= link_to "Đăng nhập", dangnhap_dangnhap_path %>
    </li>
<% end %>
        </ul>
    </nav>
</header>
<main class="container">

    <h1 class="tieude">THÊM MỚI BÀI ĐĂNG</h1>

    <div class="noidung">

        <!-- CỘT TRÁI -->
        <div class="trai">

            <label>Tiêu đề</label>
            <input type="text" placeholder="Nhập tiêu đề bài đăng">

            <label>Tóm tắt nội dung</label>
            <textarea rows="3" placeholder="Nhập tóm tắt"></textarea>

            <label>Nội dung chi tiết của bài đăng</label>
            <textarea rows="6" placeholder="Nhập nội dung"></textarea>

            <div class="image">
                <p>Hình ảnh bài viết</p>
                <div class="anhbaiviet" onclick="document.getElementById('fileanhbaiviet').click()">
                    <input type="file" id="fileanhbaiviet" accept=".pdf,.jpg,.jpeg,.png" multiple>
                    <span>📎 Click để chọn file ảnh</span>
                </div>
            </div>

            <textarea rows="4" placeholder="Nhập nội dung thêm"></textarea>

        </div>

        <!-- CỘT PHẢI -->
        <div class="phai">

            <label>Ảnh đại diện</label>
            <div class="anhdaidien" onclick="document.getElementById('fileanhdaidien').click()">
                <input type="file" id="fileanhdaidien" accept=".pdf,.jpg,.jpeg,.png" multiple>
                <span>📎 Click để chọn file ảnh</span>
            </div>
            <div class="nut">
                <button class="btn-submit">Đăng tải</button>
                <button class="btn-cancel">Hủy bỏ</button>
            </div>

        </div>

    </div>

</main>  

