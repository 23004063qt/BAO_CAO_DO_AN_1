                        <li><%= link_to "Quản lý tài khoản", qltaikhoan_qltaikhoan_path %></li>
                        <li><%= link_to "Quản lý tin tức", qltintuc_qltintuc_path %></li>
                        <li><%= link_to "Quản lý khoa - đơn vị", qlkhoa_dv_qlkhoa_dv_path %></li>
                        <li><%= link_to "Quản lý hồ sơ", xlhoso_xlhoso_path %></li>
                        <li><%= link_to "Quản lý đợt tuyển sinh","/quanlydot" %></li>
                        <li><%= link_to "Thống kê báo cáo", thongkebaocao_thongkebaocao_path %></li>
                    </ul>
                </li>
            <% end %>
            <% if current_user %>
    <li class="user-dropdown">
        <a href="#" class="user-name">
             <%= current_user.USERNAME %>
        </a>
        <ul class="user-dropdown-menu">
            <li><%= link_to "Thông tin tài khoản", thongtintaikhoan_thongtintaikhoan_path %></li>
            <li>
                <%= button_to "Đăng xuất",
                "/dangnhap/logout",
                method: :delete,
                class: "logout-btn",
                form: { style: "display:inline;" } %>
            </li>
        </ul>
    </li>
<% else %>
    <li>
        <%= link_to "Đăng nhập", dangnhap_dangnhap_path %>
    </li>
<% end %>
        </ul>
    </nav>
</header>
<main>
    <div class="actions">
        <button class="btn-add">
            <%= link_to "+Thêm", qlkhoa_dv_new_path %>
        </button>
    </div>

    <table class="bang">
        <tr class="head">
            <th>STT</th>
            <th>Mã khoa</th>
            <th>Tên khoa</th>
            <th>Mô tả</th>
            <th colspan="2">Hành động</th>
        </tr>

        <% @khoas.each_with_index do |khoa, index| %>
            <tr>
                <td><%= index + 1 %></td>
                <td><%= khoa.IDKHOA %></td>
                <td><%= khoa.TENKHOA %></td>
                <td><%= khoa.MOTA %></td>

                <td class="action-buttons">
                    <%= button_to "🗑️ Xóa",
                        "/qlkhoa_dv/delete/#{khoa.IDKHOA}",
                        method: :delete,
                        class: "btn-delete",
                        form: {
                            onsubmit: "return confirm('Bạn có chắc muốn xóa khoa này?');",
                            style: "display:inline;"
                    } %>
                </td>

                <td class="action-buttons">
                    <%= link_to "✎ Sửa",
                        "/qlkhoa_dv/edit/#{khoa.IDKHOA}",
                        class: "btn-edit"
                    %>
                </td>
            </tr>
        <% end %>
    </table>
</main>

