<header>
    <nav>
        <div class="logo">
            <%= image_tag "logovlute.png",  width: 50 %>
            Hệ Thống Tư Vấn Tuyển Sinh
        </div>
        <ul class="menu">
            <li><%= link_to "Trang chủ", trangchu_index_path %></li>
            <li><%= link_to "Thông Tin Trường", thongtintruong_thongtintruong_path %></li>
            <li><%= link_to "Tin Tức", tintuc_tintuc_path %></li>
            <li><%= link_to "Ngành Học", nganh_nganh_path %></li>
            <li><%= link_to "Lịch Tuyển Sinh", lichtuyensinh_lichtuyensinh_path %></li>
            <li><%= link_to "Nộp hồ sơ", nophoso_nophoso_path %></li>

            <% if current_user &&
                current_user.VAITRO == "ADMIN" %>
                <li class="dropdown">
                    <%= link_to "Quản trị viên", "#" %>
                    <ul class="dropdown-menu">
                        <li><%= link_to "Quản lý tài khoản", qltaikhoan_qltaikhoan_path %></li>
                        <li><%= link_to "Quản lý tin tức", qltintuc_qltintuc_path %></li>
                        <li><%= link_to "Quản lý khoa - đơn vị", qlkhoa_dv_qlkhoa_dv_path %></li>
                        <li><%= link_to "Quản lý hồ sơ", xlhoso_xlhoso_path %></li>
                        <li><%= link_to "Thống kê báo cáo", thongkebaocao_thongkebaocao_path %></li>
                    </ul>
                </li>
            <% end %>
            <% if current_user %>
                <li>
                    <%= button_to "Đăng xuất",
                    "/dangnhap/logout",
                    method: :delete,
                    class: "logout-btn",
                    form: {
                        style: "display:inline;"
                    } %>
                </li>
            <% else %>
                <li>
                    <%= link_to "Đăng nhập", dangnhap_dangnhap_path %>
                </li>
            <% end %>
        </ul>
    </nav>
</header>

<section class="schedule" id="schedule">
    <h2 class="section-title">Lịch Tuyển Sinh 2026</h2>
    <p class="section-subtitle">Theo dõi các mốc thời gian quan trọng</p>
    <div class="timeline">
        <div class="timeline-item">
            <div class="timeline-content">
                <span class="timeline-date">01/03 - 31/03/2026</span>
                <h3>Đăng Ký Xét Tuyển</h3>
                <p>Thí sinh đăng ký nguyện vọng trực tuyến và nộp hồ sơ minh chứng.</p>
            </div>
        </div>
        <div class="timeline-item">
            <div class="timeline-content">
                <span class="timeline-date">01/04 - 15/04/2026</span>
                <h3>Xét Duyệt Hồ Sơ</h3>
                <p>Nhà trường kiểm tra và xác nhận hồ sơ đăng ký của thí sinh.</p>
            </div>
        </div>
        <div class="timeline-item">
            <div class="timeline-content">
                <span class="timeline-date">27/06 - 29/06/2026</span>
                <h3>Kỳ Thi THPT Quốc Gia</h3>
                <p>Thí sinh tham dự kỳ thi THPT để lấy điểm xét tuyển đại học.</p>
            </div>
        </div>
        <div class="timeline-item">
            <div class="timeline-content">
                <span class="timeline-date">15/07/2026</span>
                <h3>Công Bố Điểm Thi</h3>
                <p>Bộ Giáo dục công bố kết quả thi THPT quốc gia.</p>
            </div>
        </div>
        <div class="timeline-item">
            <div class="timeline-content">
                <span class="timeline-date">01/08/2026</span>
                <h3>Công Bố Kết Quả Trúng Tuyển</h3>
                <p>Nhà trường công bố danh sách thí sinh trúng tuyển và hướng dẫn nhập học.</p>
            </div>
        </div>
    </div>
</section>

