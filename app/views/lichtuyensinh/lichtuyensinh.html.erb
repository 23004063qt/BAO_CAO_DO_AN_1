<section class="schedule" id="schedule">
  <h2 class="section-title">Lịch Tuyển Sinh 2026</h2>
  <p class="section-subtitle">Theo dõi các mốc thời gian quan trọng</p>
  <div class="timeline">
    <% @dot_tuyen_sinh.each do |dot| %>

  <% if Date.today < dot.NGAYBATDAU %>
    <% item_class = 'pending' %>
  <% elsif Date.today <= (dot.NGAYKETTHUC || dot.NGAYBATDAU) %>
    <% item_class = 'active' %>
  <% else %>
    <% item_class = 'expired' %>
  <% end %>

  <div class="timeline-item <%= item_class %>">
    <div class="timeline-content">
      <div class="timeline-meta">
        <% if item_class == 'active' %>
          <span class="status-active">Đang diễn ra</span>
        <% elsif item_class == 'pending' %>
          <span class="status-pending">Chưa diễn ra</span>
        <% else %>
          <span class="status-expired">Hết hạn</span>
        <% end %>
        <span class="timeline-date">
          <% if dot.NGAYKETTHUC.present? && dot.NGAYKETTHUC != dot.NGAYBATDAU %>
            <%= dot.NGAYBATDAU.strftime("%d/%m") %> – <%= dot.NGAYKETTHUC.strftime("%d/%m/%Y") %>
          <% else %>
            <%= dot.NGAYBATDAU.strftime("%d/%m/%Y") %>
          <% end %>
        </span>
      </div>
      <h3><%= dot.TENDOT %></h3>
      <p><%= dot.NOIDUNG %></p>
    </div>
  </div>

<% end %>
  </div>
</section>

