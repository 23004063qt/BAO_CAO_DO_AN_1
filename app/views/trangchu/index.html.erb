<% if notice %>
    <script>
        alert("<%= notice %>");
    </script>
<% end %>

<% if alert %>
    <script>
        alert("<%= alert %>");
    </script>
<% end %>
<header>
    <nav>
        <div class="logo">
            <%= image_tag "logovlute.png",  width: 50 %>
            Hệ Thống Tư Vấn Tuyển Sinh
        </div>
        <ul class="menu">
            <li><%= link_to "Trang chủ", trangchu_index_path %></li>
            <li><%= link_to "Thông Tin Trường", thongtintruong_thongtintruong_path %></li>
            <li><%= link_to "Tin Tức", tintuc_tintuc_path %></li>
            <li><%= link_to "Ngành Học", nganh_nganh_path %></li>
            <li><%= link_to "Lịch Tuyển Sinh", lichtuyensinh_lichtuyensinh_path %></li>
            <li><%= link_to "Nộp hồ sơ", nophoso_nophoso_path %></li>

            <% if current_user &&
                current_user.VAITRO == "ADMIN" %>
                <li class="dropdown">
                    <%= link_to "Quản trị viên", "#" %>
                    <ul class="dropdown-menu">
                        <li><%= link_to "Quản lý tài khoản", qltaikhoan_qltaikhoan_path %></li>
                        <li><%= link_to "Quản lý tin tức", qltintuc_qltintuc_path %></li>
                        <li><%= link_to "Quản lý khoa - đơn vị", qlkhoa_dv_qlkhoa_dv_path %></li>
                        <li><%= link_to "Quản lý hồ sơ", xlhoso_xlhoso_path %></li>
                        <li><%= link_to "Quản lý đợt tuyển sinh","/quanlydot" %></li>
                        <li><%= link_to "Thống kê báo cáo", thongkebaocao_thongkebaocao_path %></li>
                    </ul>
                </li>
            <% end %>
            <% if current_user %>
    <li class="user-dropdown">
        <a href="#" class="user-name">
             <%= current_user.USERNAME %>
        </a>
        <ul class="user-dropdown-menu">
            <li><%= link_to "Thông tin tài khoản", thongtintaikhoan_thongtintaikhoan_path %></li>
            <li>
                <%= button_to "Đăng xuất",
                "/dangnhap/logout",
                method: :delete,
                class: "logout-btn",
                form: { style: "display:inline;" } %>
            </li>
        </ul>
    </li>
<% else %>
    <li>
        <%= link_to "Đăng nhập", dangnhap_dangnhap_path %>
    </li>
<% end %>
        </ul>
    </nav>
</header>

<section class="hero" id="home">
   
    <div class="hero-overlay">
        <div class="hero-content">
            <h1>Hệ Thống Tư Vấn Tuyển Sinh</h1>
            <p>Kết hợp AI Chatbot - Tư vấn 24/7 - Nộp hồ sơ trực tuyến - Theo dõi kết quả</p>
            <div class="hero-buttons">
                <a href="#application" class="btn btn-primary">Nộp Hồ Sơ Ngay</a>
                <a href="#" class="btn btn-secondary" onclick="toggleChatbot()">Chat với AI</a>
            </div>
        </div>
    </div>

    <div class="hero-slider">
        <div class="slider-container">
            <div class="slide active">
                <%= image_tag "vlute1.jpg",  width: 60 %>
            </div>
            <div class="slide">
                <%= image_tag "vlute2.jpg",  width: 50 %>
            </div>
            <div class="slide">
                <%= image_tag "vlute3.jpg",  width: 50 %>
            </div>
            <div class="slide">
                <%= image_tag "vlute4.jpg",  width: 50 %>
            </div>
        </div>

        <div class="slider-dots">
            <span class="dot active" onclick="currentSlide(0)"></span>
            <span class="dot" onclick="currentSlide(1)"></span>
            <span class="dot" onclick="currentSlide(2)"></span>
            <span class="dot" onclick="currentSlide(3)"></span>
        </div>
    </div>
</section>


<section class="congcu-class">
    <div class="congcu-container">
        <div class="congcu" onclick="window.location.href='<%= tinhdiem_tinhdiem_path %>'">
            <div class="icon">🧮</div>
            <h3>Tính Điểm Thi</h3>
            <p>Tính điểm xét tuyển theo tổ hợp môn</p>
        </div>
        <div class="congcu" onclick="window.location.href='<%= nganh_nganh_path %>'">
            <div class="icon">📚</div>
            <h3>Tra Cứu Ngành</h3>
            <p>Xem thông tin các ngành đào tạo</p>
        </div>
        <div class="congcu" onclick="window.location.href='<%= lichtuyensinh_lichtuyensinh_path %>'">
            <div class="icon">📅</div>
            <h3>Lịch Tuyển Sinh</h3>
            <p>Xem lịch trình tuyển sinh chi tiết</p>
        </div>
        <div class="congcu">
            <div class="icon">📊</div>
            <h3>Tra Cứu Hồ Sơ</h3>
            <p>Theo dõi trạng thái hồ sơ của bạn</p>
        </div>
    </div>
</section>

