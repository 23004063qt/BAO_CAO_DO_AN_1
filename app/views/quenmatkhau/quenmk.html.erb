<header>
    <nav>
        <div class="logo">
            <%= image_tag "logovlute.png",  width: 50 %>
            Hệ Thống Tư Vấn Tuyển Sinh
        </div>
        <ul class="dropdown-menu">
                        <li><%= link_to "Quản lý tài khoản", qltaikhoan_qltaikhoan_path %></li>
                        <li><%= link_to "Quản lý tin tức", qltintuc_qltintuc_path %></li>
                        <li><%= link_to "Quản lý khoa - đơn vị", qlkhoa_dv_qlkhoa_dv_path %></li>
                        <li><%= link_to "Quản lý hồ sơ", xlhoso_xlhoso_path %></li>
                        <li><%= link_to "Quản lý đợt tuyển sinh","/quanlydot" %></li>
                        <li><%= link_to "Thống kê báo cáo", thongkebaocao_thongkebaocao_path %></li>
                    </ul>
    </nav>
</header>
<div class="forgot-container">

    <% if params[:step].nil? %>

        <form action="/quen-mat-khau/gui-otp" method="POST">

            <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

            <h2>Quên mật khẩu</h2>

            <input type="email"
                   name="email"
                   placeholder="Nhập email">

            <% if flash[:error] %>
                <p class="error"><%= flash[:error] %></p>
            <% end %>

            <% if flash[:success] %>
                <p class="success"><%= flash[:success] %></p>
            <% end %>

            <button type="submit">
                Gửi OTP
            </button>

        </form>

    <% end %>

    <% if params[:step] == "otp" %>

        <form action="/quen-mat-khau/xac-nhan-otp" method="POST">

            <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

            <h2>Nhập mã OTP</h2>

            <div class="otp-box">

                <% 6.times do %>

                    <input type="text"
                           name="otp[]"
                           maxlength="1"
                           class="otp-input">

                <% end %>

            </div>
            
            

            <% if flash[:error] %>
                <p class="error"><%= flash[:error] %></p>
            <% end %>

            <% if flash[:success] %>
                <p class="success"><%= flash[:success] %></p>
            <% end %>

            <button type="submit">
                Xác nhận OTP
            </button>

        </form>

    <% end %>

    <% if params[:step] == "reset" %>

        <form action="/quen-mat-khau/dat-lai" method="POST">

            <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

            <h2>Đặt lại mật khẩu</h2>

            <input type="text"
                   name="username"
                   placeholder="Tên tài khoản mới">

            <input type="password"
                   name="password"
                   placeholder="Mật khẩu mới">

            <% if flash[:error] %>
                <p class="error"><%= flash[:error] %></p>
            <% end %>

            <% if flash[:success] %>
                <p class="success"><%= flash[:success] %></p>
            <% end %>

            <button type="submit">
                Đổi mật khẩu
            </button>

        </form>

    <% end %>

</div>
<script>
  const otpInputs = document.querySelectorAll('.otp-input');
  otpInputs.forEach((inp, i) => {
    inp.addEventListener('input', () => {
      if (inp.value && i < otpInputs.length - 1) otpInputs[i + 1].focus();
    });
    inp.addEventListener('keydown', e => {
      if (e.key === 'Backspace' && !inp.value && i > 0) otpInputs[i - 1].focus();
    });
  });
</script>