<div class="sua-container">
  <h2 class="sua-tieude">CHỈNH SỬA TIN TỨC</h2>

  <%= form_with model: @tin, url: updatetintuc_path(@tin.IDTINTUC), method: :patch, local: true, multipart: true do |f| %>
    <div class="sua-noidung">

      <div class="sua-trai">
        <label>Tiêu đề</label>
        <%= f.text_field :TIEUDE, placeholder: "Nhập tiêu đề bài đăng" %>

        <label>Tóm tắt nội dung</label>
        <%= f.text_area :TOM_TAT, rows: 3, placeholder: "Nhập tóm tắt" %>

        <label>Nội dung chi tiết</label>
        <%= f.text_area :NOIDUNG, rows: 6, placeholder: "Nhập nội dung" %>

        <div class="sua-image">
          <p>Hình ảnh bài viết</p>
          <% if @tin.ANH_BAI_VIET.present? %>
            <img src="<%= @tin.ANH_BAI_VIET %>" style="width:100%;height:120px;object-fit:cover;border-radius:8px;margin-bottom:8px">
          <% end %>
          <div class="sua-anhbaiviet" onclick="document.getElementById('file-anhbaiviet').click()">
            <input type="file" id="file-anhbaiviet" name="anh_bai_viet_file" accept=".jpg,.jpeg,.png" onchange="previewAnhBaiViet(event)">
            <span id="label-anhbaiviet">📎 Click để chọn file ảnh mới</span>
            <div id="preview-anhbaiviet" style="margin-top:8px"></div>
          </div>
          <input type="text" name="tintuc[ANH_BAI_VIET]" value="<%= @tin.ANH_BAI_VIET %>" placeholder="Hoặc nhập URL ảnh..." class="sua-url-input">
        </div>

        <label>Nội dung thêm</label>
        <%= f.text_area :NOI_DUNG_THEM, rows: 4, placeholder: "Nhập nội dung thêm" %>
      </div>

      <div class="sua-phai">
        <label>Danh mục</label>
        <%= f.text_field :DANHMUC, placeholder: "Nhập danh mục" %>

        <label>Ngày đăng</label>
        <%= f.date_field :NGAYDANG %>

        <label>Ảnh đại diện</label>
        <% if @tin.ANH_DAI_DIEN.present? %>
          <img src="<%= @tin.ANH_DAI_DIEN %>" style="width:100%;height:120px;object-fit:cover;border-radius:8px;margin-bottom:8px">
        <% end %>
        <div class="sua-anhdaidien" onclick="document.getElementById('file-anhdaidien').click()">
          <input type="file" id="file-anhdaidien" name="anh_dai_dien_file" accept=".jpg,.jpeg,.png" onchange="previewAnhDaiDien(event)">
          <span id="label-anhdaidien">📎 Click để chọn file ảnh mới</span>
          <img id="preview-anhdaidien" src="" style="display:none;width:100%;margin-top:8px;border-radius:8px">
        </div>
        <input type="text" name="tintuc[ANH_DAI_DIEN]" value="<%= @tin.ANH_DAI_DIEN %>" placeholder="Hoặc nhập URL ảnh..." class="sua-url-input">

        <div class="sua-nut">
          <%= f.submit "💾 Lưu", class: "sua-btn-submit" %>
          <%= link_to "Hủy bỏ", qltintuc_qltintuc_path, class: "sua-btn-cancel" %>
        </div>
      </div>

    </div>
  <% end %>
</div>

<script>
  function previewAnhDaiDien(event) {
    const file = event.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = e => {
      const img = document.getElementById('preview-anhdaidien');
      img.src = e.target.result;
      img.style.display = 'block';
      document.getElementById('label-anhdaidien').style.display = 'none';
    };
    reader.readAsDataURL(file);
  }

  function previewAnhBaiViet(event) {
    const file = event.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = e => {
      document.getElementById('preview-anhbaiviet').innerHTML =
        `<img src="${e.target.result}" style="width:100%;height:120px;object-fit:cover;border-radius:8px">`;
      document.getElementById('label-anhbaiviet').style.display = 'none';
    };
    reader.readAsDataURL(file);
  }
</script>
