</header>
<main class="thongke-main">
  <h1>Thống kê kết quả tuyển sinh</h1>

  <div class="thongke-cards">
    <div class="tk-card">
      <span class="tk-label">Tổng hồ sơ</span>
      <span class="tk-number"><%= @tong %></span>
    </div>
    <div class="tk-card dau">
      <span class="tk-label">Đậu</span>
      <span class="tk-number"><%= @dau %></span>
    </div>
    <div class="tk-card rot">
      <span class="tk-label">Không xét</span>
      <span class="tk-number"><%= @rot %></span>
    </div>
  </div>

  <!-- Nút lọc -->
  <div class="filter-bar" style="margin-bottom:1rem">
    <button class="filter-btn active" onclick="locKetQua(this, 'all')">Tất cả</button>
    <button class="filter-btn" onclick="locKetQua(this, 'Đậu')">Đậu</button>
    <button class="filter-btn" onclick="locKetQua(this, 'Không xét')">Không xét</button>
  </div>

  <div class="xuat-nhom">
  <%= link_to "📥 Xuất tất cả", xuat_excel_path(loai: "all"), class: "btn-excel" %>
  <%= link_to "📥 Xuất đậu",    xuat_excel_path(loai: "dau"), class: "btn-excel" %>
  <%= link_to "📥 Xuất không xét", xuat_excel_path(loai: "rot"), class: "btn-excel" %>
</div>

  <table class="bang">
    <tr class="head">
      <th>STT</th>
      <th>Họ tên</th>
      <th>Ngày sinh</th>
      <th>CCCD</th>
      <th>SĐT</th>
      <th>Email</th>
      <th>Ngày nộp</th>
      <th>Kết quả</th>
    </tr>
    <% @ds_all.each_with_index do |hoso, i| %>
      <tr data-ketqua="<%= hoso.KETQUA %>">
        <td><%= i + 1 %></td>
        <td><%= hoso.thisinh&.HOTENTS %></td>
        <td><%= hoso.thisinh&.NGAYSINH&.strftime("%d/%m/%Y") %></td>
        <td><%= hoso.thisinh&.SOCCCD %></td>
        <td><%= hoso.thisinh&.SDT %></td>
        <td><%= hoso.thisinh&.EMAIL %></td>
        <td><%= hoso.NGAYNOP&.strftime("%d/%m/%Y") %></td>
        <td>
          <% if hoso.KETQUA == "Đậu" %>
            <span style="color:green;font-weight:500">Đậu</span>
          <% else %>
            <span style="color:red;font-weight:500">Không xét</span>
          <% end %>
        </td>
      </tr>
    <% end %>
  </table>
</main>

<script>
  function locKetQua(btn, ketqua) {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('tr[data-ketqua]').forEach(row => {
      if (ketqua === 'all' || row.dataset.ketqua === ketqua) {
        row.style.display = '';
      } else {
        row.style.display = 'none';
      }
    });
  }
</script>

