<script>

    let buocht = 0;
    const danhSachForm = document.querySelectorAll(".form-menu");
    const danhSachTieuDe = document.querySelectorAll(".menu2");

    function hienThiBuoc(soBuoc){

        // ẩn tất cả form
        danhSachForm.forEach(form =>
            form.classList.remove("active")
        );

        // reset thanh bước
        danhSachTieuDe.forEach(b =>
            b.classList.remove("active")
        );

        // hiện bước hiện tại
        danhSachForm[soBuoc].classList.add("active");
        danhSachTieuDe[soBuoc].classList.add("active");
    }


    // tiếp tục
    async function buocTiepTheo(){
        if (!kiemTraBuoc()) return;

        // nếu đang ở bước 1 thì kiểm tra CCCD
        if (buocht === 0) {

            let hopLe = await docCCCD();

            if (!hopLe) return; 
        }

        if(buocht < danhSachForm.length - 1){
            buocht++;
            hienThiBuoc(buocht);
        }
    }


    // quay lại
    function buocTruoc(){

        if(buocht > 0){
            buocht--;
            hienThiBuoc(buocht);
        }
    }


    // kiểm tra bước hiện tại
    function kiemTraBuoc() {
        let hopLe = true;

        // Lấy các input trong bước 
        const formHienTai = danhSachForm[buocht];
        const inputs = formHienTai.querySelectorAll(
            'input:not([type="hidden"]), select'
        );

        inputs.forEach(input => {
            if (input.value === "") {
                hopLe = false;
                input.style.border = "2px solid red"; // tô đỏ nếu thiếu
            } else {
                input.style.border = "";
            }
        });

        if (!hopLe) {
            alert("Vui lòng nhập đầy đủ thông tin trước khi sang bước tiếp theo!");
        }

        return hopLe;
    }
   
   // hàm xác thực CCCD bằng ảnh mặt trước
   async function docCCCD() {

        const fileTruoc =
            document.getElementById("filecccdt").files[0];

        if (!fileTruoc) {

            alert("Vui lòng tải ảnh CCCD!");

            return false;
        }

        document.body.style.cursor = "wait";

        try {

            const formData = new FormData();

            formData.append("filecccdt", fileTruoc);

            // lấy CSRF token Rails
            const token = document.querySelector(
                'meta[name="csrf-token"]'
            ).content;

            const response = await fetch(
                "/xac-thuc-cccd",
                {
                    method: "POST",

                    headers: {
                        "X-CSRF-Token": token
                    },

                    body: formData
                }
            );

            // kiểm tra lỗi server
            if (!response.ok) {

                const text = await response.text();

                console.log(text);

                throw new Error("Server lỗi!");
            }

            const data = await response.json();

            document.body.style.cursor = "default";

            console.log(data);

            if (data.success) {

                alert("Xác thực thành công!");

                return true;

            } else {

                alert("Không phải CCCD!");

                return false;
            }

        } catch (error) {

            document.body.style.cursor = "default";

            console.error(error);

            alert("Lỗi xác thực CCCD!");

            return false;
        }
    }

    // xử lý ẩn hiện phần nhập điểm
    const ptxt = document.getElementById("ptxt");
    const khoiNhapDiem = document.getElementById("tinhdiemhocba");
    const ketquaTohop = document.getElementById("ketqua-tohop");
    function capNhatNhapDiem() {

        if (ptxt.value === "Xét học bạ") {

            khoiNhapDiem.style.display = "block";
            ketquaTohop.style.display = "block";

        } else {

            khoiNhapDiem.style.display = "none";
            ketquaTohop.style.display = "none";
        }
    }

    // khi đổi phương thức xét tuyển
    ptxt.addEventListener("change", capNhatNhapDiem);

    // chạy lần đầu
    capNhatNhapDiem();

    // =======================
    // DANH SÁCH MÔN
    // =======================

    const dsMon = [
        "toan",
        "van",
        "anh",
        "ly",
        "hoa",
        "sinh",
        "su",
        "dia",
        "tin",
        "gdkt",
        "gdcd",
        "cn",
        "cnn"
    ];


    // =======================
    // TÍNH ĐIỂM TRUNG BÌNH 1 MÔN
    // =======================

    function tinhDiemTrungBinhMon(maMon) {

        let tong = 0;
        let dem = 0;

        [10,11,12].forEach(lop => {

            [1,2].forEach(hk => {

                const input = document.getElementById(
                    `l${lop}hk${hk}-${maMon}`
                );

                let diem = parseFloat(input.value);

                if (!isNaN(diem)) {

                    tong += diem;
                    dem++;
                }

            });

        });

        if (dem === 0) return 0;

        return tong / dem; 
    }


    // =======================
    // TÍNH TOÀN BỘ ĐIỂM MÔN
    // =======================

    function layTatCaDiemMon() {

        return {

            toan: tinhDiemTrungBinhMon("toan"),
            van: tinhDiemTrungBinhMon("van"),
            anh: tinhDiemTrungBinhMon("anh"),
            ly: tinhDiemTrungBinhMon("ly"),
            hoa: tinhDiemTrungBinhMon("hoa"),
            sinh: tinhDiemTrungBinhMon("sinh"),
            su: tinhDiemTrungBinhMon("su"),
            dia: tinhDiemTrungBinhMon("dia"),
            tin: tinhDiemTrungBinhMon("tin"),
            gdkt: tinhDiemTrungBinhMon("gdkt"),
            gdcd: tinhDiemTrungBinhMon("gdcd"),
            cn: tinhDiemTrungBinhMon("cn"),
            cnn: tinhDiemTrungBinhMon("cnn")

        };
    }


    // =======================
    // MAP TÊN MÔN
    // API -> INPUT
    // =======================

    const mapMonHoc = {

        "Toán": "toan",

        "Ngữ văn": "van",
        "Ngữ Văn": "van",
        "Văn": "van",

        "Tiếng Anh": "anh",
        "Anh": "anh",

        "Vật lý": "ly",
        "Vật Lý": "ly",
        "Lý": "ly",

        "Hóa học": "hoa",
        "Hóa": "hoa",

        "Sinh học": "sinh",
        "Sinh Học": "sinh",
        "Sinh": "sinh",

        "Lịch sử": "su",
        "Lịch Sử": "su",
        "Sử": "su",

        "Địa lý": "dia",
        "Địa": "dia",

        "Tin học": "tin",
        "Tin Học": "tin",
        "Tin": "tin",

        "GDKTPL": "gdkt",
        "GDKT và PL": "gdkt",

        "GDCD": "gdcd",

        "Công nghệ": "cn",
        "Công nghệ công nghiệp": "cn",

        "Công nghệ nông nghiệp": "cnn"
    };

    // =======================
    // TÍNH ĐIỂM 1 TỔ HỢP
    // =======================

    function tinhDiemToHop(tohop, diemMon) {

        let tong = 0;

        // lấy 3 môn trong tổ hợp
        const dsMonHoc = [
            tohop.MON1,
            tohop.MON2,
            tohop.MON3
        ];

        for (let mon of dsMonHoc) {

            if (!mon) continue;

            mon = mon.trim();

            let maMon = mapMonHoc[mon];

            if (!maMon) {

                console.log("Không map được môn:", mon);

                return 0;
            }

            tong += diemMon[maMon];
        }

        return tong;
    }

    // =======================
    // LẤY TỔ HỢP CAO NHẤT
    // =======================

    async function tinhToHopCaoNhat(idNganh, elementId) {

        if (!idNganh) return;

        try {

            const response = await fetch(
                `/lay-tohop/${idNganh}`
            );

            if (!response.ok) {
                throw new Error("Không lấy được tổ hợp");
            }

            const data = await response.json();

            const dsToHop = data.data || data;

            const diemMon = layTatCaDiemMon();

            let maxDiem = 0;

            let tenToHop = "";

            dsToHop.forEach(th => {
                console.log("TO HOP:", th);

                const diem = tinhDiemToHop(
                    th,
                    diemMon
                );

                if (diem > maxDiem) {

                    maxDiem = diem;

                    tenToHop = th.TENTOHOP;

                    if(elementId === "kq-nganh1"){
                        document.getElementById("tohop_nv1").value = tenToHop;
                    }

                    if(elementId === "kq-nganh2"){
                        document.getElementById("tohop_nv2").value = tenToHop;
                    }
                }

            });

            document.getElementById(elementId).innerHTML = `
                Tổ hợp cao nhất:
                <b>${tenToHop}</b>
                <br>
                Điểm xét học bạ:
                <b>${maxDiem.toFixed(2)}</b>
            `;

        } catch(error) {

            console.error(error);

        }
    }

    // =======================
    // TỰ ĐỘNG TÍNH
    // =======================

    const nv1 = document.querySelector(
        'select[name="nguyenvong1"]'
    );

    const nv2 = document.querySelector(
        'select[name="nguyenvong2"]'
    );


    // =======================
    // BUTTON TÍNH ĐIỂM
    // =======================

    const btnTinhDiem =
        document.getElementById("btn-tinhdiem");

    btnTinhDiem.addEventListener("click", async () => {

        if (!nv1.value && !nv2.value) {

            alert("Vui lòng chọn ngành xét tuyển!");

            return;
        }

        // tính nguyện vọng 1
        if (nv1.value) {

            await tinhToHopCaoNhat(
                nv1.value,
                "kq-nganh1"
            );
        }

        // tính nguyện vọng 2
        if (nv2.value) {

            await tinhToHopCaoNhat(
                nv2.value,
                "kq-nganh2"
            );
        }

        const diemMon = layTatCaDiemMon();

        document.getElementById("diem_mon_hidden").value = JSON.stringify(diemMon);
    });


    // khi đổi ngành
    nv1.addEventListener("change", () => {

        tinhToHopCaoNhat(
            nv1.value,
            "kq-nganh1"
        );

    });

    nv2.addEventListener("change", () => {

        tinhToHopCaoNhat(
            nv2.value,
            "kq-nganh2"
        );

    });
</script>