            <p>Vui lòng kiểm tra lại thông tin trước khi nộp.</p>
            <button type="submit" class="btn-nop">Nộp hồ sơ</button>
        </div>
        <div class="nut-dieuhuong">
            <button type="button" onclick="buocTruoc()" class="btn-dh">← Quay lại</button>
            <button type="button" onclick="buocTiepTheo()" class="btn-dh">Tiếp theo →</button>
