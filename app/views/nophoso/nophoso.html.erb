<div class="header">
        <div class="logo">
            <%= image_tag "logovlute.png",  width: 50 %>
            Hệ Thống Tư Vấn Tuyển Sinh
        </div>
        <ul class="menu">
            <li><%= link_to "Trang chủ", trangchu_index_path %></li>
            <li>Thông Tin Trường</li>
            <li>Tin Tức</li>
            <li>Ngành Học</li>
            <li>Lịch Tuyển Sinh</li>
            <li><%= link_to "Nộp hồ sơ", nophoso_nophoso_path %></li>
            <li><%= link_to "Đăng nhập", dangnhap_dangnhap_path %></li>
        </ul>
</div>

<div class="content">
    <label><h1>NỘP HỒ SƠ ĐĂNG KÝ TUYỂN SINH</h1></label>
    <form class="form_thisinh">
        <label><h3>Thông tin cá nhân</h3></label>
        <table>
            <tr>
                <th>Họ và tên: </th>
                <th>
                    <input type="text" name="hoten" placeholder="Nhập họ và tên">
                </th>
            </tr>

            <tr>
                <th>Số CCCD: </th>
                <th>
                    <input type="text" name="cccd" placeholder="Nhập số căn cước công dân">
                </th>
            </tr>

            <tr>
                <th>Ngày sinh: </th>
                <th>
                    <input type="date" name="ngaysinh">
                </th>
            </tr>

            <tr>
                <th>Số điện thoại: </th>
                <th>
                    <input type="text" name="sdt" placeholder="Nhập số điện thoại">
                </th>
            </tr>

            <tr>
                <th>Email: </th>
                <th>
                    <input type="email" name="email" placeholder="Nhập địa chỉ email">
                </th>
            </tr>

            <tr>
                <th>Địa chỉ: </th>
                <th>
                    <input type="text" name="diachi" placeholder="Nhập địa chỉ thường trú">
                </th>
            </tr>
        </table>
        <label><h3>Thông tin học tập</h3></label>
        <table>
            <tr>
                <th>Trường THPT: </th>
                <th>
                    <input type="text" name="truong" placeholder="Nhập tên trường">
                </th>
            </tr>
            <tr>
                <th>Năm tốt nghiệp: </th>
                <th>
                    <input type="text" name="namtotnghiep" placeholder="Nhập năm tốt nghiệp">
                </th>
            </tr>
            <tr>
                <th>Chọn nguyện vọng 1: </th>
                <th>
                    <select id="nv1" required>
                        <option value="">-- Chọn ngành --</option>
                        <option value="CNTT">Công Nghệ Thông Tin</option>
                        <option value="QTKD">Quản Trị Kinh Doanh</option>
                        <option value="KTCK">Kỹ Thuật Cơ Khí</option>
                    </select>
                </th>
            </tr>
            <tr>
                <th>Chọn nguyện vọng 2: </th>
                <th>
                    <select id="nv2" required>
                        <option value="">-- Chọn ngành --</option>
                        <option value="CNTT">Công Nghệ Thông Tin</option>
                        <option value="QTKD">Quản Trị Kinh Doanh</option>
                        <option value="KTCK">Kỹ Thuật Cơ Khí</option>
                    </select>
                </th>
            </tr>
            <tr>
                <th>Chọn phương thức xét tuyển</th>
                <th>
                    <select id="xettuyen" required>
                        <option value="">-- Chọn phương thức --</option>
                        <option value="CNTT">Xét điểm thi</option>
                        <option value="QTKD">Xứt điểm học bạ</option>
                        <option value="KTCK">Ưu tiên xét tuyển</option>
                    </select>
                </th>
            </tr>
        </table>
        <label><h3>Tải lên thông tin hồ sơ</h3></label>
        <label>Hồ Sơ Minh Chứng (PDF, JPG, PNG - Tối đa 5MB)</label>
        <div class="file-upload" onclick="document.getElementById('fileInput').click()">
            <input type="file" id="fileInput" accept=".pdf,.jpg,.jpeg,.png" multiple>
            <span>
                <p>📎 Click để chọn file hoặc kéo thả vào đây </p>
                <p> Bao gồm: Bản sao CMND, Học bạ, Giấy khai sinh </p>
            </span>
            
        </div>
        <button class="btn-nop">Nộp hồ sơ</button>
    </form>
</div>
</div>
<div class="footer">
    <div class="footer-content">
        <div class="footer1">
            <h3>Về Chúng Tôi</h3>
            <p style="color: #94a3b8; line-height: 1.8;">
                Hệ thống tư vấn tuyển sinh.
            </p>
        </div>
        <div class="footer1">
            <h3>Liên Kết Nhanh</h3>
            <ul>
                <li>Ngành học<</li>
                <li>Lịch tuyển sinh</li>
                <li>Nộp hồ sơ</li>
                <li>Câu hỏi thường gặp</li>
            </ul>
        </div>
        <div class="footer1">
            <h3>Liên Hệ</h3>
            <ul>
                <li>Hotline: 123</li>
                <li>Email: tuyensinh@vlute.edu.vn</li>
                <li>Địa chỉ: Vĩnh Long</li>
                <li>Giờ làm việc: 8:00 - 17:00</li>
            </ul>
        </div>
    </div>
    <div class="footer2">
        <p>&copy; 2026 Hệ Thống Tư Vấn Tuyển Sinh </p>
    </div>
</div>