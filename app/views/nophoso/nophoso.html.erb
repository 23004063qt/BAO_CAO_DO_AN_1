                    ["cn", "Công nghệ công nghiệp"],
                    ["cnn", "Công nghệ nông nghiệp"]
                    ]
                %>
                <!-- Tạo biến lớp, lấy từng phần tử lớp trong danh sách lớp -->
                <% ds_lop.each do |lop| %>

                <div class="khoi-lop">

                    <h3 class="tieu-de-lop">
                        Lớp <%= lop %>
                    </h3>

                    <% ds_hk.each do |hk| %>

                        <h4 class="tieu-de-hocky">
                            Học kì <%= hk %> lớp <%= lop %>
                        </h4>

                        <div class="luoi-mon-hoc">

