                    ds_lop = [10,11,12]

                    #Danh sách học kỳ 
                    ds_hk = [1, 2]

                    # Danh sách môn học
                    ds_mon = [
                    ["toan", "Toán"],
                    ["van", "Ngữ Văn"],
                    ["anh", "Tiếng Anh"],
                    ["ly", "Vật Lý"],
                    ["hoa", "Hóa"],
