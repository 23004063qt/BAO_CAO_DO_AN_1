</header>
<main class="qldiemchuan-page">
    <h1>Quản lý điểm chuẩn</h1>
    <%= form_with url: "/qldiemchuan/import_excel", multipart: true do %>

    <div>
        <label>Đợt tuyển sinh</label>
        <select name="iddot">
        <% @dots.each do |dot| %>
            <option value="<%= dot.IDDOT %>"><%= dot.TENDOT %></option>
        <% end %>
        </select>
    </div>

    <br>
        <div>
        <label>File học bạ</label>
            <input type="file" name="file_hocba">
        </div>

        <div>
            <label>File THPT</label>
            <input type="file" name="file_thpt">
        </div>

        <div>
            <label>File ĐGNL</label>
            <input type="file" name="file_dgnl">
        </div>
    <br>

    <button type="submit">Cập nhật điểm chuẩn</button>

    <% end %>
    <%= button_to "Công bố điểm chuẩn",
      "/qldiemchuan/cong_bo",
      method: :post,
      class: "btn-congbo",
      data: {
        confirm: "Bạn có chắc muốn công bố điểm chuẩn?"
      } %>

    <hr>

    <h2>Danh sách điểm chuẩn</h2>

    <table border="1">
    <tr>
        <th>Ngành</th>
        <th>Đợt</th>
        <th>Phương thức</th>
        <th>Điểm</th>
    </tr>

    <% @diemchuans.each do |dc| %>
        <tr>
        <td><%= dc.nganh.TENNGANH %></td>
        <td><%= dc.dot.TENDOT %></td>
        <td><%= dc.phuongthuc.TENPHUONGTHUC %></td>
        <td><%= dc.DIEM %></td>
        </tr>
    <% end %>
    </table>
</main>

