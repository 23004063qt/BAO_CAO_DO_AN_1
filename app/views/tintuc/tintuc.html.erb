            <li><%= link_to "Lịch Tuyển Sinh", lichtuyensinh_lichtuyensinh_path %></li>
            <li><%= link_to "Nộp hồ sơ", nophoso_nophoso_path %></li>

            <% if current_user &&
                current_user.VAITRO == "ADMIN" %>
                <li class="dropdown">
                    <%= link_to "Quản trị viên", "#" %>
                    <ul class="dropdown-menu">
                        <li><%= link_to "Quản lý tài khoản", qltaikhoan_qltaikhoan_path %></li>
                        <li><%= link_to "Quản lý tin tức", qltintuc_qltintuc_path %></li>
                        <li><%= link_to "Quản lý khoa - đơn vị", qlkhoa_dv_qlkhoa_dv_path %></li>
                        <li><%= link_to "Quản lý hồ sơ", xlhoso_xlhoso_path %></li>
                        <li><%= link_to "Thống kê báo cáo", thongkebaocao_thongkebaocao_path %></li>
                    </ul>
                </li>
            <% end %>
            <% if current_user %>
    <li class="user-dropdown">
        <a href="#" class="user-name">
             <%= current_user.USERNAME %>
        </a>
        <ul class="user-dropdown-menu">
            <li><%= link_to "Thông tin tài khoản", thongtintaikhoan_thongtintaikhoan_path %></li>
            <li>
                <%= button_to "Đăng xuất",
                "/dangnhap/logout",
                method: :delete,
                class: "logout-btn",
                form: { style: "display:inline;" } %>
            </li>
        </ul>
    </li>
<% else %>
    <li>
        <%= link_to "Đăng nhập", dangnhap_dangnhap_path %>
    </li>
<% end %>
        </ul>
    </nav>
</header>

<div class="page-wrapper">
    <main>
        <div class="filter-bar">
            <span class="filter-label">Lọc theo:</span>
            <button class="filter-btn active" onclick="setFilter(this)">Tất cả</button>
            <button class="filter-btn" onclick="setFilter(this)">Tin tức</button>
            <button class="filter-btn" onclick="setFilter(this)">Tuyển sinh</button>
            <button class="filter-btn" onclick="setFilter(this)">Hợp tác</button>
            <button class="filter-btn" onclick="setFilter(this)">Hướng nghiệp</button>
        </div>
        <div class="news-featured" onclick="window.location.href='<%= noidungtin_noidungtin_path %>'">
            <div class="news-featured-main">
                <div class="featured-img"><%= image_tag "vfast.jpg",  width: 600 %></div>
                <div class="featured-body">
                    <h2>VLUTE "Tiếp nhận thiết bị tài trợ đào tạo lĩnh vực ô tô điện" từ VinFast</h2>
                    <p>Sáng 19/3/2026, tại Nhà thi đấu đa năng, Trường Đại học Sư phạm Kỹ thuật Vĩnh Long (VLUTE) đã tổ chức chương trình tiếp nhận tài trợ với sự tham gia của nhiều doanh nghiệp và đông đảo giảng viên, sinh viên.</p>
                    <span class="featured-date">19/03/2026</span>
                </div>
            </div>
        </div>
        <div class="news-divider">
            <span class="news-divider-title">Tin Mới Nhất</span>
            <div class="news-divider-line"></div>
        </div>
 
        <div class="news-grid">
 
            <div class="news-card">
                <div class="card-img">
                    <%= image_tag "ts.jpg",  width: 400 %>
                    <span class="card-tag">Tuyển sinh</span>
                </div>
                <div class="card-body">
                    <div class="card-date">14/03/2026</div>
                    <div class="card-title">Tư vấn tuyển sinh năm 2026, đợt 3 – Ngày hội kết nối và trải nghiệm VLUTE OPEN DAY</div>
                    <div class="card-excerpt">Chiều ngày 14/03/2026 Trường Đại học Sư phạm Kỹ thuật Vĩnh Long tổ chức chương trình tư vấn tuyển sinh đợt 3...</div>
                </div>
            </div>
        </div>

         <div class="pagination">
            <button class="page-btn arrow">‹</button>
            <button class="page-btn">1</button>
            <button class="page-btn">2</button>
            <button class="page-btn">3</button>
            <button class="page-btn">4</button>
            <button class="page-btn">5</button>
            <button class="page-btn arrow">›</button>
        </div>

    </main>
</div>

