<div class="page-wrapper">
  <main>
    <div class="filter-bar">
      <span class="filter-label">Lọc theo:</span>
      <button class="filter-btn active" onclick="setFilter(this, 'all')">Tất cả</button>
      <% Tintuc.distinct.pluck(:DANHMUC).compact.each do |danhmuc| %>
        <button class="filter-btn" onclick="setFilter(this, '<%= danhmuc %>')" data-danhmuc="<%= danhmuc %>">
          <%= danhmuc %>
        </button>
      <% end %>
    </div>

    <% if @tin_noi_bat %>
      <div class="news-featured" onclick="window.location.href='<%= noidungtin_noidungtin_path(id: @tin_noi_bat.IDTINTUC) %>'">
        <div class="featured-img">
          <%= image_tag @tin_noi_bat.ANH_DAI_DIEN.presence || "placeholder.jpg" %>
        </div>
        <div class="featured-body">
          <span class="news-card-category"><%= @tin_noi_bat.DANHMUC %></span>
          <h2><%= @tin_noi_bat.TIEUDE %></h2>
          <p><%= @tin_noi_bat.TOM_TAT %></p>
          <span class="featured-date"><%= @tin_noi_bat.NGAYDANG&.strftime("%d/%m/%Y") %></span>
        </div>
      </div>
    <% end %>

    <div class="section-title">Tin tức mới nhất</div>

    <div class="news-list">
      <% @tintuc_list.each do |tin| %>
        <div class="news-card" data-danhmuc="<%= tin.DANHMUC %>"
             onclick="window.location.href='<%= noidungtin_noidungtin_path(id: tin.IDTINTUC) %>'">
          <% if tin.ANH_DAI_DIEN.present? %>
            <%= image_tag tin.ANH_DAI_DIEN, class: "news-card-img" %>
          <% end %>
          <div class="news-card-body">
            <span class="news-card-category"><%= tin.DANHMUC %></span>
            <h3><%= tin.TIEUDE %></h3>
            <p><%= truncate(tin.TOM_TAT, length: 120) %></p>
            <span class="news-card-date"><%= tin.NGAYDANG&.strftime("%d/%m/%Y") %></span>
          </div>
        </div>
      <% end %>
    </div>

    <div class="pagination">
      <button class="page-btn arrow">‹</button>
      <button class="page-btn active">1</button>
      <button class="page-btn">2</button>
      <button class="page-btn">3</button>
      <button class="page-btn arrow">›</button>
    </div>
  </main>
</div>

<script>
  function setFilter(btn, danhmuc) {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.news-card').forEach(card => {
      if (danhmuc === 'all' || card.dataset.danhmuc === danhmuc) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });
  }
</script>

