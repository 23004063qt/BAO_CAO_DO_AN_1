<div class="page-wrapper">
  <main>
    <!-- Filter bar -->
    <div class="filter-bar">
      <span class="filter-label">Lọc theo:</span>
      <button class="filter-btn active" onclick="setFilter(this, 'all')">Tất cả</button>
      <% Tintuc.distinct.pluck(:DANHMUC).compact.each do |danhmuc| %>
        <button class="filter-btn" onclick="setFilter(this, '<%= danhmuc %>')" data-danhmuc="<%= danhmuc %>">
          <%= danhmuc %>
        </button>
      <% end %>
    </div>

    <!-- Tin nổi bật -->
    <% if @tin_noi_bat %>
      <div class="news-featured" onclick="window.location.href='<%= noidungtin_noidungtin_path(id: @tin_noi_bat.id) %>'">
        <div class="news-featured-main">
          <div class="featured-img">
            <%= image_tag @tin_noi_bat.ANH_DAI_DIEN.presence || "placeholder.jpg", width: 600 %>
          </div>
          <div class="featured-body">
            <h2><%= @tin_noi_bat.TIEUDE %></h2>
            <p><%= @tin_noi_bat.TOM_TAT %></p>
            <span class="featured-date">
              <%= @tin_noi_bat.NGAYDANG&.strftime("%d/%m/%Y") %>
            </span>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Divider -->
    <div class="news-divider">
      <span class="news-divider-title">Tin Mới Nhất</span>
      <div class="news-divider-line"></div>
    </div>

   <!-- News grid -->
<div class="news-grid">
  <% @tin_moi.each do |tin| %>
    <div class="news-card" data-danhmuc="<%= tin.DANHMUC %>">
      <div class="card-img">
        <img src="/<%= tin.ANH_DAI_DIEN %>" width="400" alt="<%= tin.TIEUDE %>">
        <span class="card-tag"><%= tin.DANHMUC %></span>
      </div>
      <div class="card-body">
        <div class="card-date"><%= tin.NGAYDANG&.strftime("%d/%m/%Y") %></div>
        <div class="card-title"><%= tin.TIEUDE %></div>
        <div class="card-excerpt"><%= tin.TOM_TAT %></div>
      </div>
    </div>
  <% end %>
</div>

    <!-- Pagination -->
    <div class="pagination">
      <button class="page-btn arrow">‹</button>
      <button class="page-btn">1</button>
      <button class="page-btn">2</button>
      <button class="page-btn">3</button>
      <button class="page-btn arrow">›</button>
    </div>
  </main>
</div>

<script>
  function setFilter(btn, danhmuc) {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    document.querySelectorAll('.news-card').forEach(card => {
      if (danhmuc === 'all' || card.dataset.danhmuc === danhmuc) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });
  }
</script>

