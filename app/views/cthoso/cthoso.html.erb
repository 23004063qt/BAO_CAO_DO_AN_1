<div class="header">
    <div class="logo">
        <%= image_tag "logovlute.png", width: 50 %>
        Hệ Thống Tư Vấn Tuyển Sinh
    </div>

    <ul class="menu">
        <li><%= link_to "Trang chủ", trangchu_index_path %></li>
        <li><%= link_to "Thông Tin Trường", thongtintruong_thongtintruong_path %></li>
        <li><%= link_to "Tin Tức", tintuc_tintuc_path %></li>
        <li><%= link_to "Ngành Học", nganh_nganh_path %></li>
        <li><%= link_to "Lịch Tuyển Sinh", lichtuyensinh_lichtuyensinh_path %></li>
        <li><%= link_to "Nộp hồ sơ", nophoso_nophoso_path %></li>

        <% if current_user && current_user.VAITRO == "ADMIN" %>
            <li class="dropdown">
                <%= link_to "Quản trị viên", "#" %>

                <ul class="dropdown-menu">
                    <li><%= link_to "Quản lý tài khoản", qltaikhoan_qltaikhoan_path %></li>
                    <li><%= link_to "Quản lý tin tức", qltintuc_qltintuc_path %></li>
                    <li><%= link_to "Quản lý khoa - đơn vị", qlkhoa_dv_qlkhoa_dv_path %></li>
                    <li><%= link_to "Quản lý hồ sơ", xlhoso_xlhoso_path %></li>
                    <li><%= link_to "Thống kê báo cáo", thongkebaocao_thongkebaocao_path %></li>
                </ul>
            </li>
        <% end %>

        <% if current_user %>
            <li>
                <%= button_to "Đăng xuất",
                "/dangnhap/logout",
                method: :delete,
                class: "logout-btn",
                form: {
                    style: "display:inline;"
                } %>
            </li>
        <% else %>
            <li>
                <%= link_to "Đăng nhập", dangnhap_dangnhap_path %>
            </li>
        <% end %>
    </ul>
</div>

<div class="content">
    <div class="noidung">

        <h2 class="tieude">Chi tiết hồ sơ thí sinh</h2>

        <!-- THÔNG TIN CÁ NHÂN -->
        <div class="khungthongtin">

            <h3>Thông tin cá nhân</h3>

            <table class="bangthongtin">

                <tr>
                    <th>Họ và tên</th>
                    <td><%= @thisinh.HOTENTS %></td>
                </tr>

                <tr>
                    <th>Giới tính</th>
                    <td><%= @thisinh.GIOITINH %></td>
                </tr>

                <tr>
                    <th>Ngày sinh</th>
                    <td><%= @thisinh.NGAYSINH %></td>
                </tr>

                <tr>
                    <th>Nơi sinh</th>
                    <td><%= @thisinh.NOISINH %></td>
                </tr>

                <tr>
                    <th>Dân tộc</th>
                    <td><%= @thisinh.DANTOC %></td>
                </tr>

                <tr>
                    <th>Tỉnh thường trú</th>
                    <td><%= @thisinh.TINHTT %></td>
                </tr>

                <tr>
                    <th>Đối tượng ưu tiên</th>
                    <td><%= @thisinh.DTUT %></td>
                </tr>

                <tr>
                    <th>Số CCCD</th>
                    <td><%= @thisinh.SOCCCD %></td>
                </tr>

                <tr>
                    <th>Email</th>
                    <td><%= @thisinh.EMAIL %></td>
                </tr>

                <tr>
                    <th>SĐT</th>
                    <td><%= @thisinh.SDT %></td>
                </tr>

                <tr>
                    <th>Địa chỉ</th>
                    <td><%= @thisinh.DIACHI %></td>
                </tr>

                <tr>
                    <th>Trường THPT</th>
                    <td><%= @thisinh.THPT %></td>
                </tr>

                <tr>
                    <th>Năm tốt nghiệp</th>
                    <td><%= @thisinh.NAMTN %></td>
                </tr>

            </table>

            <!-- ẢNH -->
            <div class="khuvucanh">

                <div class="khunganh">
                    <p>CCCD mặt trước</p>

                    <% if @thisinh.ANHCCCDT.present? %>
                    <%= image_tag "/images/#{@thisinh.ANHCCCDT}", width: 250 %>
                    <% else %>
                        <div class="khongcoanh">Không có ảnh</div>
                    <% end %>
                </div>

                <div class="khunganh">
                    <p>CCCD mặt sau</p>

                    <% if @thisinh.ANHCCCDS.present? %>
                    <%= image_tag "/images/#{@thisinh.ANHCCCDS}", width: 250 %>
                    <% else %>
                        <div class="khongcoanh">Không có ảnh</div>
                    <% end %>
                </div>

                <div class="khunganh">
                    <p>Giấy khai sinh</p>

                    <% if @thisinh.GIAYKHAISINH.present? %>
                        <%= image_tag "/images/#{@thisinh.GIAYKHAISINH}", width: 250 %>
                    <% else %>
                        <div class="khongcoanh">Không có ảnh</div>
                    <% end %>
                </div>

            </div>
        </div>



        <!-- THÔNG TIN HỌC TẬP -->
        <div class="khungthongtin">

            <h3>Thông tin học tập</h3>

            <table class="bangthongtin">

                <tr>
                    <th>Hạnh kiểm</th>
                    <td><%= @thisinh.HANHKIEM %></td>
                </tr>

                <tr>
                    <th>Học lực năm 12</th>
                    <td><%= @thisinh.KQHT12 %></td>
                </tr>

            </table>

            <div class="khuvucanh">

                <div class="khunganh">
                    <p>Ảnh học bạ</p>

                    <% if @thisinh.ANHHOCBA.present? %>
                    <%= image_tag "/images/#{@thisinh.ANHHOCBA}", width: 250 %>
                    <% else %>
                        <div class="khongcoanh">Không có ảnh</div>
                    <% end %>
                </div>

            </div>
        </div>



        <!-- THÔNG TIN XÉT TUYỂN -->
        <div class="khungthongtin">

            <h3>Thông tin xét tuyển</h3>

            <% @nguyenvongs.each do |nv| %>

            <h4>
                Nguyện vọng <%= nv.THUTU %>
            </h4>

            <table class="bangthongtin">

                <tr>
                <th>Mã hồ sơ</th>
                <td><%= nv.IDHOSO %></td>
                </tr>

                <tr>
                <th>Ngành đăng ký</th>
                <td>
                    <%= nv.nganh&.TENNGANH %>
                </td>
                </tr>

                <tr>
                <th>Phương thức xét tuyển</th>
                <td>
                    <%= nv.phuongthucxettuyen&.TENPHUONGTHUC %>
                </td>
                </tr>

                <tr>
                <th>Trạng thái</th>
                <td>
                    <%= nv.TRANGTHAI %>
                </td>
                </tr>

            </table>

            <% end %>

        </div>


        <!-- NÚT DUYỆT -->
        <div class="nut">

            <%= button_to "Từ chối hồ sơ",
            tuchoi_hoso_path(@thisinh.IDTHISINH),
            method: :patch,
            class: "tuchoi" %>

            <%= button_to "Duyệt hồ sơ",
            duyet_hoso_path(@thisinh.IDTHISINH),
            method: :patch,
            class: "duyet" %>

        </div>

    </div>
</div>


<div class="footer">

    <div class="footer-content">

        <div class="footer1">
            <h3>Về Chúng Tôi</h3>

            <p style="color: #94a3b8; line-height: 1.8;">
                Hệ thống tư vấn tuyển sinh.
            </p>
        </div>

        <div class="footer1">
            <h3>Liên Kết Nhanh</h3>

            <ul>
                <li>Ngành học</li>
                <li>Lịch tuyển sinh</li>
                <li>Nộp hồ sơ</li>
                <li>Câu hỏi thường gặp</li>
            </ul>
        </div>

        <div class="footer1">
            <h3>Liên Hệ</h3>

            <ul>
                <li>Hotline: 123</li>
                <li>Email: tuyensinh@vlute.edu.vn</li>
                <li>Địa chỉ: Vĩnh Long</li>
                <li>Giờ làm việc: 8:00 - 17:00</li>
            </ul>
        </div>

    </div>

    <div class="footer2">
        <p>&copy; 2026 Hệ Thống Tư Vấn Tuyển Sinh</p>
    </div>

</div>