<header>
    <nav>
        <div class="logo">
            <%= image_tag "logovlute.png",  width: 50 %>
            Hệ Thống Tư Vấn Tuyển Sinh
        </div>
        <ul class="menu">
            <li><%= link_to "Trang chủ", trangchu_index_path %></li>
            <li><%= link_to "Thông Tin Trường", thongtintruong_thongtintruong_path %></li>
            <li><%= link_to "Tin Tức", tintuc_tintuc_path %></li>
            <li>Ngành Học</li>
            <li><%= link_to "Lịch Tuyển Sinh", lichtuyensinh_lichtuyensinh_path %></li>
            <li><%= link_to "Nộp hồ sơ", nophoso_nophoso_path %></li>
            <li><%= link_to "Đăng nhập", dangnhap_dangnhap_path %></li>
        </ul>
    </nav>
</header>

<div class="page-header">
    <div class="page-header-inner">
        <h1>Chương Trình Đào Tạo Đại Học</h1>
        <div class="tabs">
            <button class="tab-btn active">Tất Cả</button>
            <button class="tab-btn" >Công Nghệ Thông Tin</button>
            <button class="tab-btn" >Kinh Tế - Luật</button>
            <button class="tab-btn" >Cơ Khí</button>
            <button class="tab-btn" >Cơ Khí Động Lực</button>
            <button class="tab-btn" >Điện - Điện Tử</button>
            <button class="tab-btn" >Sinh Hóa - Thực Phẩm </button>
            <button class="tab-btn" >Chính Trị - Ngoại Ngữ </button>
            <button class="tab-btn" >Sư Phạm KT và XHNV</button>
        </div>
    </div>
</div>

<div class="page-wrapper">
    <div class="toolbar">
        <div class="search-box">
            <input type="text" placeholder="Tìm kiếm ngành học..." oninput="filterNganh(this.value)">
        </div>
        <div class="filter-group">
            <button class="filter-chip active" onclick="setFilter(this, 'all')">Tất cả</button>
            <button class="filter-chip" onclick="setFilter(this, 'ky-thuat')">Kỹ thuật</button>
            <button class="filter-chip" onclick="setFilter(this, 'kinh-te')">Kinh tế</button>
            <button class="filter-chip" onclick="setFilter(this, 'cong-nghe')">Công nghệ</button>
            <button class="filter-chip" onclick="setFilter(this, 'su-pham')">Sư phạm</button>
            <button class="filter-chip" onclick="setFilter(this, 'khac')">Khác</button>
        </div>
    </div>
 
    <div class="section-title">
        <span class="title-text">Tất cả ngành đào tạo</span>
        <span id="countLabel">(20 ngành)</span>
    </div>
    <div class="nganh-grid" id="nganhGrid">
 
        <div class="nganh-card" data-cat="ky-thuat">
            <div class="nganh-img-placeholder"><%= image_tag "ktkh.jpg",  width: 500 %></div>
            <div class="nganh-body">
                <div class="nganh-khoa">Khoa Kỹ thuật Hóa học</div>
                <div class="nganh-ten">Ngành Kỹ thuật Hóa học</div>
                <div class="nganh-mo-ta">Thông tin chi tiết về chương trình học. Xem tại đây để tìm hiểu thêm về ngành Kỹ thuật Hóa học tại VLUTE.</div>
                <div class="nganh-footer">
                    <span class="nganh-ma">Mã ngành: 7520301</span>
                    <a href="#" class="xem-them">Xem thêm →</a>
                </div>
            </div>
        </div>
    </div>
</div>

<footer>
    <div class="footer-content">
        <div class="footer1">
            <h3>Về Chúng Tôi</h3>
            <p style="color: #94a3b8; line-height: 1.8;">
                Hệ thống tư vấn tuyển sinh.
            </p>
        </div>
        <div class="footer1">
            <h3>Liên Kết Nhanh</h3>
            <ul>
                <li>Ngành học<</li>
                <li>Lịch tuyển sinh</li>
                <li>Nộp hồ sơ</li>
                <li>Câu hỏi thường gặp</li>
            </ul>
        </div>
        <div class="footer1">
            <h3>Liên Hệ</h3>
            <ul>
                <li>Hotline: 123</li>
                <li>Email: tuyensinh@vlute.edu.vn</li>
                <li>Địa chỉ: Vĩnh Long</li>
                <li>Giờ làm việc: 8:00 - 17:00</li>
            </ul>
        </div>
    </div>
    <div class="footer2">
        <p>&copy; 2026 Hệ Thống Tư Vấn Tuyển Sinh </p>
    </div>
</footer>