<style>
.tohop-toggle-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-top: 8px;
  padding: 5px 12px;
  font-size: 12px;
  font-weight: 500;
  color: #1e6fb5;
  background: #e8f1fb;
  border: 1px solid #b5d4f4;
  border-radius: 20px;
  cursor: pointer;
  transition: background 0.2s, color 0.2s;
  user-select: none;
}
.tohop-toggle-btn:hover { background: #d0e6f7; }
.tohop-toggle-btn svg { transition: transform 0.25s; }
.tohop-toggle-btn.open svg { transform: rotate(180deg); }

.tohop-table-wrap {
  display: none;
  margin-top: 10px;
  overflow: hidden;
  animation: slideDown 0.25s ease;
}
.tohop-table-wrap.open { display: block; }

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}

.tohop-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
  border-radius: 8px;
  overflow: hidden;
  border: 1px solid #dde6f0;
}
.tohop-table thead tr {
  background: #1e6fb5;
  color: #fff;
}
.tohop-table thead th {
  padding: 6px 10px;
  text-align: left;
  font-weight: 600;
  letter-spacing: 0.3px;
}
.tohop-table tbody tr:nth-child(even) { background: #f0f6fd; }
.tohop-table tbody tr:hover { background: #ddeaf8; }
.tohop-table tbody td {
  padding: 5px 10px;
  border-bottom: 1px solid #e4ecf5;
  color: #1a2a3a;
}
.tohop-table tbody td:first-child {
  font-weight: 700;
  color: #1e6fb5;
  white-space: nowrap;
  width: 72px;
}

/* ---- Floating Action Button ---- */
.fab-tohop {
  position: fixed;
  bottom: 120px;
  right: 24px;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
  cursor: pointer;
  text-decoration: none;
}
.fab-tohop-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 62px;
  height: 62px;
  border-radius: 50%;
  background: linear-gradient(135deg, #1e6fb5 0%, #0d4a82 100%);
  box-shadow: 0 4px 18px rgba(30,111,181,0.45);
  animation: fabPulse 2.4s ease-in-out infinite;
  transition: transform 0.18s;
}
.fab-tohop:hover .fab-tohop-inner {
  transform: scale(1.1);
  animation-play-state: paused;
}
@keyframes fabPulse {
  0%   { box-shadow: 0 4px 18px rgba(30,111,181,0.45); }
  50%  { box-shadow: 0 4px 28px rgba(30,111,181,0.75), 0 0 0 8px rgba(30,111,181,0.12); }
  100% { box-shadow: 0 4px 18px rgba(30,111,181,0.45); }
}
.fab-tohop-icon {
  width: 28px;
  height: 28px;
  fill: none;
  stroke: #fff;
  stroke-width: 1.8;
  stroke-linecap: round;
  stroke-linejoin: round;
}
.fab-tohop-label {
  margin-top: 6px;
  font-size: 10.5px;
  font-weight: 700;
  text-align: center;
  color: #1e6fb5;
  line-height: 1.25;
  text-shadow: 0 1px 2px rgba(255,255,255,0.8);
  background: rgba(255,255,255,0.88);
  border-radius: 10px;
  padding: 2px 7px;
  box-shadow: 0 1px 5px rgba(30,111,181,0.2);
  white-space: nowrap;
}
.fab-tohop-tooltip {
  position: absolute;
  right: 70px;
  bottom: 12px;
  background: #0d4a82;
  color: #fff;
  font-size: 12px;
  padding: 5px 10px;
  border-radius: 6px;
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s;
}
.fab-tohop-tooltip::after {
  content: '';
  position: absolute;
  right: -7px;
  top: 50%;
  transform: translateY(-50%);
  border: 5px solid transparent;
  border-left-color: #0d4a82;
}
.fab-tohop:hover .fab-tohop-tooltip { opacity: 1; }

#tohop-anchor {
  display: block;
  height: 0;
  visibility: hidden;
}
</style>

