  border: 1.5px solid #c8ddf0;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 4px 24px rgba(30,111,181,0.1);
}
.atr {
  display: flex;
  align-items: stretch;
  border-bottom: 1px solid #ddeaf7;
  transition: background 0.15s;
  cursor: default;
}
.atr:hover { background: #e4f0fb; }
.atr.hidden { display: none; }
.atr-code {
  min-width: 68px;
  width: 68px;
  background: #1e6fb5;
  color: #fff;
  font-size: 13px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 0.5px;
  flex-shrink: 0;
  border-right: 2px solid #1660a0;
}
.atr:nth-child(even) .atr-code { background: #1660a0; }
.atr-subjects {
  padding: 9px 14px;
  font-size: 13px;
  color: #1a2a3a;
  line-height: 1.45;
  display: flex;
  align-items: center;
}
.atr-tt {
  font-size: 10px;
  color: #7a9ab8;
  margin-right: 8px;
  min-width: 18px;
}
</style>

<script>
(function(){
  var ALL_TH = [
    <% Tohopmon.all.each_with_index do |th, i| %>
      ["<%= th.TENTOHOP %>", "<%= th.MON1 %>, <%= th.MON2 %>, <%= th.MON3 %>"]<%= i < Tohopmon.count - 1 ? ',' : '' %>
    <% end %>
  ];

  var grid = document.getElementById('allTohopGrid');
  if (grid) {
    ALL_TH.forEach(function(item, i) {
      var row = document.createElement('div');
      row.className = 'atr';
      row.dataset.code = item[0].toLowerCase();
      row.dataset.subjects = item[1].toLowerCase();
      row.innerHTML =
        '<div class="atr-code">' + item[0] + '</div>' +
        '<div class="atr-subjects">' +
          '<span class="atr-tt">' + (i+1) + '</span>' +
          item[1] +
        '</div>';
      grid.appendChild(row);
    });
  }

  window.filterAllTohop = function(val) {
    var q = val.toLowerCase().trim();
    var rows = document.querySelectorAll('.atr');
    var count = 0;
    rows.forEach(function(r) {
      var match = !q || r.dataset.code.includes(q) || r.dataset.subjects.includes(q);
      r.classList.toggle('hidden', !match);
      if (match) count++;
    });
    var badge = document.getElementById('allTohopCount');
    if (badge) badge.textContent = count + ' tổ hợp';
  };
})();
</script>

