    "X27":"Toán, CN công nghiệp, Tiếng Anh",
    "X53":"Toán, GDKT và PL, Tin học",
    "X54":"Toán, GDKT và PL, CN công nghiệp",
    "X67":"Văn, Sinh, Tin học",
    "X69":"Văn, Sinh, CN nông nghiệp",
    "X70":"Văn, Sử, GDKT và PL",
    "X71":"Văn, Sử, Tin học",
    "X72":"Văn, Sử, CN công nghiệp",
    "X74":"Văn, Địa, GDKT và PL",
