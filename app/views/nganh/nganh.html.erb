<script>
function setFilter(button, category) {
    const cards = document.querySelectorAll('.nganh-card');
    const tabButtons = document.querySelectorAll('.tab-btn');
    const filterChips = document.querySelectorAll('.filter-chip');

    tabButtons.forEach(btn => btn.classList.remove('active'));
    filterChips.forEach(chip => chip.classList.remove('active'));

    if (button) {
        button.classList.add('active');
    }

    let visibleCount = 0;
    cards.forEach(card => {
        const cardCategory = card.getAttribute('data-cat');
        let showCard = false;

        if (category === 'all') {
            showCard = true;
        } else if (category === 'ky-thuat') {
            showCard = ['co-khi', 'co-khi-dong-luc', 'dien-dien-tu'].includes(cardCategory);
        } else if (category === 'cong-nghe') {
            showCard = cardCategory === 'cong-nghe';
        } else {
            showCard = cardCategory === category;
        }

        if (showCard) {
            card.style.display = 'block';
            visibleCount++;
        } else {
            card.style.display = 'none';
        }
    });

    document.getElementById('countLabel').textContent = `(${visibleCount} ngành)`;
}

function filterNganh(searchTerm) {
    const cards = document.querySelectorAll('.nganh-card');
    let visibleCount = 0;
    cards.forEach(card => {
        const title = card.querySelector('.nganh-ten').textContent.toLowerCase();
        const info = Array.from(card.querySelectorAll('.nganh-info')).map(el => el.textContent.toLowerCase()).join(' ');
        if (title.includes(searchTerm.toLowerCase()) || info.includes(searchTerm.toLowerCase())) {
            card.style.display = 'block';
            visibleCount++;
        } else {
            card.style.display = 'none';
        }
    });
    document.getElementById('countLabel').textContent = `(${visibleCount} ngành)`;
}

document.addEventListener('DOMContentLoaded', function() {
    setFilter(document.querySelector('.tab-btn.active'), 'all');
});
</script>

