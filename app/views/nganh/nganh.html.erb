<% end %>
<header>
    <nav>
        <div class="logo">
            <%= image_tag "logovlute.png",  width: 50 %>
            Hệ Thống Tư Vấn Tuyển Sinh
        </div>
        <ul class="menu">
            <li><%= link_to "Trang chủ", trangchu_index_path %></li>
            <li><%= link_to "Thông Tin Trường", thongtintruong_thongtintruong_path %></li>
            <li><%= link_to "Tin Tức", tintuc_tintuc_path %></li>
            <li><%= link_to "Ngành Học", nganh_nganh_path %></li>
            <li><%= link_to "Lịch Tuyển Sinh", lichtuyensinh_lichtuyensinh_path %></li>
            <li><%= link_to "Nộp hồ sơ", nophoso_nophoso_path %></li>

            <% if current_user &&
                current_user.VAITRO == "ADMIN" %>
                <li class="dropdown">
                    <%= link_to "Quản trị viên", "#" %>
                    <ul class="dropdown-menu">
                        <li><%= link_to "Quản lý tài khoản", qltaikhoan_qltaikhoan_path %></li>
                        <li><%= link_to "Quản lý tin tức", qltintuc_qltintuc_path %></li>
                        <li><%= link_to "Quản lý khoa - đơn vị", qlkhoa_dv_qlkhoa_dv_path %></li>
                        <li><%= link_to "Quản lý hồ sơ", xlhoso_xlhoso_path %></li>
                        <li><%= link_to "Thống kê báo cáo", thongkebaocao_thongkebaocao_path %></li>
                    </ul>
                </li>
            <% end %>
            <% if current_user %>
    <li class="user-dropdown">
        <a href="#" class="user-name">
             <%= current_user.USERNAME %>
        </a>
        <ul class="user-dropdown-menu">
            <li><%= link_to "Thông tin tài khoản", thongtintaikhoan_thongtintaikhoan_path %></li>
            <li>
                <%= button_to "Đăng xuất",
                "/dangnhap/logout",
                method: :delete,
                class: "logout-btn",
                form: { style: "display:inline;" } %>
            </li>
        </ul>
    </li>
<% else %>
    <li>
        <%= link_to "Đăng nhập", dangnhap_dangnhap_path %>
    </li>
<% end %>
        </ul>
    </nav>
</header>

<div class="page-header">
    <div class="page-header-inner">
        <h1>Chương Trình Đào Tạo Đại Học</h1>
        <div class="tabs">
            <button class="tab-btn active" onclick="setFilter(this, 'all')">Tất Cả</button>
            <button class="tab-btn" onclick="setFilter(this, 'cong-nghe')">Công Nghệ Thông Tin</button>
            <button class="tab-btn" onclick="setFilter(this, 'kinh-te')">Kinh Tế - Luật</button>
            <button class="tab-btn" onclick="setFilter(this, 'co-khi')">Cơ Khí</button>
            <button class="tab-btn" onclick="setFilter(this, 'co-khi-dong-luc')">Cơ Khí Động Lực</button>
            <button class="tab-btn" onclick="setFilter(this, 'dien-dien-tu')">Điện - Điện Tử</button>
            <button class="tab-btn" onclick="setFilter(this, 'sinh-hoa')">Sinh Hóa - Thực Phẩm </button>
            <button class="tab-btn" onclick="setFilter(this, 'khac')">Chính Trị - Ngoại Ngữ </button>
            <button class="tab-btn" onclick="setFilter(this, 'su-pham')">Sư Phạm KT và XHNV</button>
        </div>
    </div>
</div>

<div class="page-wrapper">
