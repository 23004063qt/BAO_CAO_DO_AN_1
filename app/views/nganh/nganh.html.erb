<script>
function setFilter(button, category) {
    // Remove active class from all tab-btn and filter-chip
    document.querySelectorAll('.tab-btn, .filter-chip').forEach(btn => btn.classList.remove('active'));
    
    // Add active class to clicked button
    if (button) button.classList.add('active');
    
    // Show/hide cards based on category
    const cards = document.querySelectorAll('.nganh-card');
    const kyThuatCats = ['co-khi', 'co-khi-dong-luc', 'dien-dien-tu', 'sinh-hoa'];
    let visibleCount = 0;
    cards.forEach(card => {
        const cardCat = card.getAttribute('data-cat');
        if (category === 'all' || cardCat === category || (category === 'ky-thuat' && kyThuatCats.includes(cardCat))) {
            card.style.display = 'block';
            visibleCount++;
        } else {
            card.style.display = 'none';
        }
    });
    
    // Update count label
    document.getElementById('countLabel').textContent = `(${visibleCount} ngành)`;
}

function filterNganh(searchTerm) {
    const cards = document.querySelectorAll('.nganh-card');
    let visibleCount = 0;
    cards.forEach(card => {
        const title = card.querySelector('.nganh-ten').textContent.toLowerCase();
        const info = Array.from(card.querySelectorAll('.nganh-info')).map(el => el.textContent.toLowerCase()).join(' ');
        if (title.includes(searchTerm.toLowerCase()) || info.includes(searchTerm.toLowerCase())) {
            card.style.display = 'block';
            visibleCount++;
        } else {
            card.style.display = 'none';
        }
    });
    document.getElementById('countLabel').textContent = `(${visibleCount} ngành)`;
}

// Initialize with 'all' filter
document.addEventListener('DOMContentLoaded', function() {
    setFilter(document.querySelector('.tab-btn.active'), 'all');
});
</script>

