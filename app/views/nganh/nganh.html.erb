    "C03":"Văn, Toán, Sử",
    "C04":"Văn, Toán, Địa",
    "C06":"Văn, Hóa, Địa",
    "C07":"Văn, Lý, Sử",
    "C08":"Văn, Hóa, Sinh",
    "C09":"Văn, Lý, Địa",
    "C12":"Văn, Sinh, Sử",
    "C13":"Văn, Sinh, Địa",
    "C14":"Văn, Toán, GDCD",
    "C15":"Văn, Toán, KHXH",
    "C18":"Văn, Sinh, GDCD",
    "C19":"Văn, Sử, GDCD",
    "C20":"Văn, Địa, GDCD",
    "C26":"Văn, Hóa, GDCD",
    "D01":"Toán, Văn, Tiếng Anh",
    "D07":"Toán, Hóa, Tiếng Anh",
    "D08":"Toán, Sinh, Tiếng Anh",
    "D09":"Toán, Sử, Tiếng Anh",
    "D10":"Toán, Địa, Tiếng Anh",
    "D11":"Văn, Lý, Tiếng Anh",
    "D14":"Văn, Sử, Tiếng Anh",
    "D15":"Văn, Địa, Tiếng Anh",
    "D66":"Văn, GDCD, Tiếng Anh",
    "D84":"Toán, GDCD, Tiếng Anh",
    "D96":"Toán, KHXH, Tiếng Anh",
    "X01":"Toán, Văn, GDKT và PL",
    "X02":"Toán, Văn, Tin học",
    "X03":"Toán, Văn, CN nông nghiệp",
    "X04":"Toán, Văn, CN công nghiệp",
    "X05":"Toán, Lý, GDKT và PL",
    "X06":"Toán, Lý, Tin học",
    "X07":"Toán, Lý, CN công nghiệp",
    "X08":"Toán, Lý, CN nông nghiệp",
    "X09":"Toán, Hóa, GDKT và PL",
    "X10":"Toán, Hóa, Tin học",
    "X12":"Toán, Hóa, CN nông nghiệp",
