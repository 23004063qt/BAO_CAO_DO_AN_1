    "X78":"Văn, GDKT và PL, Tiếng Anh",
    "X79":"Văn, Tin học, Tiếng Anh",
    "X80":"Văn, CN công nghiệp, Tiếng Anh",
    "X81":"Văn, CN nông nghiệp, Tiếng Anh",
    "Y08":"Văn, GDKT và PL, CN công nghiệp",
    "Y10":"Văn, Tin học, CN công nghiệp"
  };

  function parseCodes(text) {
    var clean = text.replace(/\(.*?\)/g, '').replace(/Tổ hợp\s*:/i, '');
    var parts  = clean.split(/[\s,]+/);
    var codes  = [];
    parts.forEach(function(p) {
      p = p.trim();
      if (p && TH[p]) codes.push(p);
    });
    return codes;
  }

  var grid = document.getElementById('nganhGrid');
  if (grid) {
    var anchor = document.createElement('span');
    anchor.id = 'tohop-anchor';
    grid.parentNode.insertBefore(anchor, grid);
  }

  document.querySelectorAll('.nganh-card').forEach(function(card) {
    var infoEl = null;
    card.querySelectorAll('.nganh-info').forEach(function(el) {
      if (!infoEl && el.textContent.includes('Tổ hợp')) infoEl = el;
    });
    if (!infoEl) return;

    var codes = parseCodes(infoEl.textContent);
    if (!codes.length) return;

    var rows = codes.map(function(c) {
      return '<tr><td>' + c + '</td><td>' + TH[c] + '</td></tr>';
    }).join('');

    var tableHtml =
      '<table class="tohop-table">' +
        '<thead><tr><th>Mã TH</th><th>Môn xét tuyển</th></tr></thead>' +
        '<tbody>' + rows + '</tbody>' +
      '</table>';

    var btn = document.createElement('button');
    btn.className = 'tohop-toggle-btn';
    btn.innerHTML =
      '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>' +
      'Chi tiết tổ hợp (' + codes.length + ')';

    var wrap = document.createElement('div');
    wrap.className = 'tohop-table-wrap';
    wrap.innerHTML = tableHtml;

    btn.addEventListener('click', function() {
      var isOpen = wrap.classList.toggle('open');
      btn.classList.toggle('open', isOpen);
    });

    var actions = card.querySelector('.nganh-actions');
    if (actions) {
      actions.appendChild(btn);
      actions.appendChild(wrap);
    } else {
      var body = card.querySelector('.nganh-body');
      if (body) { body.appendChild(btn); body.appendChild(wrap); }
    }
  });

  var fab = document.getElementById('fabTohop');
  if (fab) {
    fab.addEventListener('click', function(e) {
      e.preventDefault();
      var target = document.getElementById('allTohopSection');
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  }

})();
</script>
